# Copy to .env to override defaults. All variables are optional.
NOISEGUARD_APP_NAME=NoiseGuard AI
NOISEGUARD_ENVIRONMENT=development
NOISEGUARD_API_HOST=0.0.0.0
NOISEGUARD_API_PORT=8000
NOISEGUARD_SAMPLE_RATE=16000
NOISEGUARD_MAX_UPLOAD_MB=25

# Frontend only (not read by pydantic-settings; exported directly)
NOISEGUARD_API_URL=http://localhost:8000/api/v1
